# Pterodactyl panel URL, without a trailing slash.
PteroApi_Url=https://panel.example.com

# Pterodactyl application API key. Used to list servers.
PteroApi_AppKey=ptla_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pterodactyl client API key. Used to send power signals and read server state.
PteroApi_ClientKey=ptlc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required NUT server connection.
NUT_ServerIP=192.168.50.10
NUT_ServerPort=3493
NUT_UPS_NAME=ups

# Optional NUT auth. Leave empty if your NUT server does not require login.
NUT_Login=
NUT_Password=

# Agent list. Keep this as one JSON line for dotenv parsing.
AgentInfo=[{"name":"Node-1","ip":"192.168.50.101","mac":"AA:BB:CC:DD:EE:FF","port":5858}]
